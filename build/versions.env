# WriteOnce OS — pinned upstream versions for Phase 0 / Phase 2.
# To bump a version: change the number here, blank the corresponding line in
# checksums.txt, re-run ./fetch.sh, copy the new hash from sources/*.next-lock
# into checksums.txt after spot-checking it against the upstream announcement.

# --- Cross-toolchain (LFS chapter 5) ------------------------------------------
BINUTILS_VERSION=2.43.1
GCC_VERSION=14.2.0
GLIBC_VERSION=2.40
MPFR_VERSION=4.2.1       # GCC dependency
GMP_VERSION=6.3.0        # GCC dependency
MPC_VERSION=1.3.1        # GCC dependency
ISL_VERSION=0.27         # GCC dependency (optional but recommended)

# --- Kernel -------------------------------------------------------------------
LINUX_MAJOR=6.x
LINUX_VERSION=6.12.10    # LTS series

# --- Temporary userspace (LFS chapter 6) --------------------------------------
M4_VERSION=1.4.19
NCURSES_VERSION=6.5
BASH_VERSION=5.2.32
COREUTILS_VERSION=9.5
DIFFUTILS_VERSION=3.10
FILE_VERSION=5.45
FINDUTILS_VERSION=4.10.0
GAWK_VERSION=5.3.0
GREP_VERSION=3.11
GZIP_VERSION=1.13
MAKE_VERSION=4.4.1
PATCH_VERSION=2.7.6
SED_VERSION=4.9
TAR_VERSION=1.35
XZ_VERSION=5.6.2

# --- BusyBox (transitional /init for Phase 2) ---------------------------------
BUSYBOX_VERSION=1.37.0

# --- LFS environment ----------------------------------------------------------
# $LFS is the sysroot under construction; $LFS/tools is the cross-toolchain.
# Both paths must NOT contain spaces. The cross-tools live in a sibling
# directory (build/cross-tools) and are exposed at $LFS/tools via symlink, so
# the LFS book commands using $LFS/tools work verbatim while the repo layout
# stays clean.
LFS_TGT=x86_64-lfs-linux-gnu
LFS_USER=lfs             # optional dedicated build user; see check-host.sh
