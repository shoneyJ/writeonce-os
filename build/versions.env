# WriteOnce OS — pinned upstream versions for Phase 0 / Phase 2.
# To bump a version: change the number here, blank the corresponding line in
# checksums.txt, re-run ./fetch.sh, copy the new hash from sources/*.next-lock
# into checksums.txt after spot-checking it against the upstream announcement.

# --- Cross-toolchain (LFS chapter 5) ------------------------------------------
BINUTILS_VERSION=2.43.1
GCC_VERSION=14.2.0
GLIBC_VERSION=2.40
MPFR_VERSION=4.2.1       # GCC dependency
GMP_VERSION=6.3.0        # GCC dependency
MPC_VERSION=1.3.1        # GCC dependency
ISL_VERSION=0.27         # GCC dependency (optional but recommended)

# --- Kernel -------------------------------------------------------------------
LINUX_MAJOR=6.x
LINUX_VERSION=6.12.10    # LTS series

# --- Temporary userspace (LFS chapter 6) --------------------------------------
M4_VERSION=1.4.19
NCURSES_VERSION=6.5
BASH_VERSION=5.2.32
COREUTILS_VERSION=9.5
DIFFUTILS_VERSION=3.10
FILE_VERSION=5.45
FINDUTILS_VERSION=4.10.0
GAWK_VERSION=5.3.0
GREP_VERSION=3.11
GZIP_VERSION=1.13
MAKE_VERSION=4.4.1
PATCH_VERSION=2.7.6
SED_VERSION=4.9
TAR_VERSION=1.35
XZ_VERSION=5.6.2

# --- BusyBox (transitional /init for Phase 2) ---------------------------------
BUSYBOX_VERSION=1.37.0

# --- Phase 8 / Round 1: base substrate (08-base-substrate.sh) -----------------
# Foundation libraries needed by Xorg, GTK4, D-Bus, PipeWire, PAM. Pinned to
# late-2024 / early-2025 stable releases.
ZLIB_VERSION=1.3.1
BROTLI_VERSION=1.1.0
EXPAT_VERSION=2.6.4
LIBFFI_VERSION=3.4.6
LIBXML2_VERSION=2.13.5
UTIL_MACROS_VERSION=1.20.1
LIBPNG_VERSION=1.6.44
LIBJPEG_TURBO_VERSION=3.0.4
FREETYPE_VERSION=2.13.3
FONTCONFIG_VERSION=2.15.0
LINUX_PAM_VERSION=1.6.1
# libxcrypt — provides libcrypt.so (split out of glibc 2.38+).
# linux-pam's pam_pwhistory + pam_unix modules need crypt(3).
LIBXCRYPT_VERSION=4.4.36
DBUS_VERSION=1.16.0
# zstd — shader-cache compression; Mesa target runtime dep.
ZSTD_VERSION=1.5.6

# --- Phase 8 / Round 2: X11 protocol + libraries (09-x11-stack.sh) ------------
# Layer 1 — protocol headers
XORGPROTO_VERSION=2024.1
XCB_PROTO_VERSION=1.17.0
# Layer 2 — core libs
LIBXAU_VERSION=1.0.11
XTRANS_VERSION=1.5.0
LIBXCB_VERSION=1.17.0
LIBX11_VERSION=1.8.10
# Layer 3 — extension libs
LIBXEXT_VERSION=1.3.6
LIBICE_VERSION=1.1.1
LIBSM_VERSION=1.2.4
LIBXFIXES_VERSION=6.0.1
LIBXDAMAGE_VERSION=1.1.6
LIBXCOMPOSITE_VERSION=0.4.6
LIBXCURSOR_VERSION=1.2.2
LIBXRENDER_VERSION=0.9.11
LIBXFT_VERSION=2.3.8
LIBXRANDR_VERSION=1.5.4
LIBXINERAMA_VERSION=1.1.5
LIBXI_VERSION=1.8.1
LIBXTST_VERSION=1.2.4
LIBXKBCOMMON_VERSION=1.7.0
# Layer 4 — xcb-util collection
XCB_UTIL_VERSION=0.4.1
XCB_UTIL_IMAGE_VERSION=0.4.1
XCB_UTIL_KEYSYMS_VERSION=0.4.1
XCB_UTIL_WM_VERSION=0.4.2
XCB_UTIL_RENDERUTIL_VERSION=0.3.10
XCB_UTIL_CURSOR_VERSION=0.1.5
# Layer 5 — keymap data
XKEYBOARD_CONFIG_VERSION=2.43

# --- Phase 8 / Round 3: xorg-server + drivers (10-xorg-server.sh) -------------
# Device hotplug — xorg-server's -Dudev=true requires libudev. eudev is
# the Gentoo-maintained udev fork; we use it instead of systemd's udev
# to avoid dragging in systemd itself.
EUDEV_VERSION=3.2.14
# DRM/KMS foundation
LIBDRM_VERSION=2.4.124
# X-side deps
LIBPCIACCESS_VERSION=0.18.1
LIBXFONT2_VERSION=2.0.6
# libfontenc — Xorg's font encoding lookups, required by libXfont2.
LIBFONTENC_VERSION=1.1.8
# libxshmfence — shared-memory fence sync; Mesa DRI3 path needs it.
LIBXSHMFENCE_VERSION=1.3.2
# libXxf86vm — XFree86 video-mode extension; Mesa uses for legacy DRI.
LIBXXF86VM_VERSION=1.1.6
# libxkbfile — xkb keymap file parser, required by xorg-server.
LIBXKBFILE_VERSION=1.1.3
LIBEPOXY_VERSION=1.5.10
# pixman — 2D rasteriser used by xorg-server (Composite, Render) + cairo.
PIXMAN_VERSION=0.43.4
# Input device chain  (kernel evdev → libevdev → libinput → xf86-input-libinput)
LIBEVDEV_VERSION=1.13.3
MTDEV_VERSION=1.1.7
LIBINPUT_VERSION=1.27.1
# Mesa — pinned to 24.0.9 (last release before `with_intel_clc` was made
# implicitly required by `with_gallium_iris`). Mesa 24.1+ unconditionally
# spawns a native build of intel_clc + mesa_clc that mixes build/host
# meson machines and breaks the cross-build. 24.0.9 supports our T450
# Broadwell HD 5500 iris feature set fully (OpenGL 4.6, GLSL 4.60).
MESA_VERSION=24.0.9
# The X server itself + the libinput driver
XORG_SERVER_VERSION=21.1.16
XF86_INPUT_LIBINPUT_VERSION=1.5.0

# --- Phase 8 / Round 4: GTK4 stack (11-gtk-stack.sh) --------------------------
# Foundation
GLIB_VERSION=2.82.5
GOBJECT_INTROSPECTION_VERSION=1.82.0
# Text rendering
HARFBUZZ_VERSION=10.2.0
CAIRO_VERSION=1.18.2
PANGO_VERSION=1.54.0
# Image + math
GDK_PIXBUF_VERSION=2.42.12
GRAPHENE_VERSION=1.10.8
# Runtime data
SHARED_MIME_INFO_VERSION=2.4
HICOLOR_ICON_THEME_VERSION=0.18
ADWAITA_ICON_THEME_VERSION=47.0
# Toolkit
GTK4_VERSION=4.16.7

# --- Phase 8 / Round 5: audio (12-audio-stack.sh) -----------------------------
# Lua is wireplumber's policy/scripting layer.
LUA_VERSION=5.4.7
ALSA_LIB_VERSION=1.2.13
PIPEWIRE_VERSION=1.2.7
WIREPLUMBER_VERSION=0.5.7

# --- Phase 8 / Round 6: network (13-network-stack.sh) -------------------------
# ell = "Embedded Linux Library", a small async event-loop + crypto + DBus lib
# that iwd is built on. Maintained by Intel alongside iwd.
ELL_VERSION=0.69
# iwd = "iNet Wireless Daemon" — Intel's modern WPA-supplicant replacement.
IWD_VERSION=3.3
# iproute2 = modern userspace network config (ip, tc, ss, bridge).
IPROUTE2_VERSION=6.13.0
# iputils = ping, traceroute, arping, tracepath.
IPUTILS_VERSION=20240905
# dhcpcd = DHCP client (wired interface; iwd handles its own wifi DHCP).
DHCPCD_VERSION=10.1.0

# --- Phase 9: i3 + i3More — EXTERNAL ARTIFACTS, NOT BUILT HERE ----------------
# i3 (forked) and i3More are built OUTSIDE writeonce-os, using i3More's
# own build pipeline (see .agents/reference/i3More/Dockerfile.i3 +
# justfile). The operator runs in i3More's repo:
#
#   just i3-image          # build the i3-build container
#   just i3-build          # meson + ninja inside Dockerfile.i3 (Ubuntu deps)
#   just i3-stage          # meson install --destdir vendor/i3/build/install-root
#   sudo just i3-install   # copy to /usr/local on the workstation (optional)
#
#   docker compose run --rm dev cargo build --release …
#   sudo install -Dm755 dist/i3more* /opt/i3more/bin/
#
# Then writeonce-os's 17-stage-sysroot.sh reads:
#   .agents/reference/i3More/vendor/i3/build/install-root/usr/local/   → i3
#   /opt/i3more/bin/                                                    → i3More
#
# No Phase 9 packages are fetched here; no Phase 9 versions are pinned.

# --- LFS environment ----------------------------------------------------------
# $LFS is the sysroot under construction; $LFS/tools is the cross-toolchain.
# Both paths must NOT contain spaces. The cross-tools live in a sibling
# directory (build/cross-tools) and are exposed at $LFS/tools via symlink, so
# the LFS book commands using $LFS/tools work verbatim while the repo layout
# stays clean.
LFS_TGT=x86_64-lfs-linux-gnu
LFS_USER=lfs             # optional dedicated build user; see check-host.sh
